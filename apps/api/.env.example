# ==========================================
# SprinTask API - Variables de Entorno
# ==========================================
# Copiar este archivo como .env y configurar
# para producción.
#
# ⚠️ NUNCA subir .env al repositorio
# ==========================================

# ==========================================
# Puerto del Servidor
# ==========================================
PORT=3001

# ==========================================
# Subcarpeta de la Aplicación (Opcional)
# ==========================================
# Usar solo si se despliega en subcarpeta (ej: dominio.com/sprintask/)
# Dejar vacío si se despliega en raíz del dominio (dominio.com/)
# Debe coincidir con baseUrl en config.json del frontend
# Ejemplos: "sprintask", "app", "mi-app"
APP_SUBPATH=

# ==========================================
# Base de Datos (MySQL)
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_sprintask
DB_PASSWORD=contraseña_segura
DB_NAME=sprintask_db

# ==========================================
# JWT Secret (Autenticación)
# ==========================================
# Generar con: openssl rand -base64 32
JWT_SECRET=cambia_esto_por_un_secreto_seguro_generado_aleatoriamente

# ==========================================
# Email / SMTP (Notificaciones)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notificaciones@tudominio.com
SMTP_PASSWORD=contraseña_app
SMTP_FROM=noreply@tudominio.com

# ==========================================
# Entorno
# ==========================================
NODE_ENV=production

# ==========================================
# Frontend URL (Para logs y CORS)
# ==========================================
# En producción: tu dominio (sin subcarpeta)
# En desarrollo: dejar vacío o localhost
FRONTEND_URL=https://pixelycodigo.com
