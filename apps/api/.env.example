# Entorno
NODE_ENV=development

# Servidor
PORT=3001
HOST=localhost

# Base de Datos (MAMP usa puerto 8889)
DB_HOST=localhost
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=sprintask

# JWT
JWT_SECRET=tu_secreto_muy_seguro_cambia_esto_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@sprintask.com

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Eliminados (días para borrado permanente)
ELIMINADOS_DIAS_GRACIA=30

# Logging
LOG_LEVEL=debug
# Niveles disponibles: error, warn, info, http, debug
