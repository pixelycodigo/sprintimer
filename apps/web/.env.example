# ==========================================
# SprinTask Web - Variables de Entorno
# ==========================================

# URL Base para el frontend
# ==========================================
# En desarrollo: usar '/' o la ruta que necesites
# En producción: El build usa rutas relativas ('./') automáticamente
# Este valor solo afecta el modo desarrollo
VITE_BASE_URL=/

# URL de la API (ruta relativa para producción)
# ==========================================
# En desarrollo: http://localhost:3001/api
# En producción: /api (se lee desde config.json)
VITE_API_URL=/api

# Nombre de la aplicación
VITE_APP_NAME=SprinTask
