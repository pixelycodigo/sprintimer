{
  "name": "sprintimer-backend",
  "version": "1.0.0",
  "description": "Backend para SprinTimer - Plataforma de gestión de proyectos freelance",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:fresh": "knex migrate:fresh",
    "seed": "knex seed:run",
    "init-super-admin": "node scripts/init-super-admin.js",
    "init-admin": "node scripts/init-admin.js",
    "create-super-admin": "node scripts/create-super-admin.js",
    "cleanup-eliminados": "node scripts/cleanup-eliminados.js"
  },
  "keywords": [
