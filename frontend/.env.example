# ===========================================
# VARIABLES DE ENTORNO - SprinTimer Frontend
# ===========================================

# URL de la API del Backend
# - Desarrollo: http://localhost:5000/api
# - Producción: https://tu-dominio.com/api
VITE_API_URL=http://localhost:5000/api

# ===========================================
# INSTRUCCIONES DE USO
# ===========================================
# 1. Copia este archivo a .env.local para desarrollo:
#    cp .env.example .env.local
#
# 2. Para producción, crea .env.production con la URL de tu backend:
#    VITE_API_URL=https://tu-api-backend.com/api
#
# 3. Las variables con prefijo VITE_ están disponibles en el código
#    Ejemplo: import.meta.env.VITE_API_URL
# ===========================================
